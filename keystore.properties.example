# Copia este archivo a "keystore.properties" (sin .example) y rellena los valores reales.
# El archivo keystore.properties NUNCA debe commitearse al repo (ya esta en .gitignore).
#
# Las contrasenas las eliges tu al generar el keystore con:
#   .\scripts\generar-keystore.ps1
#
# storeFile es la ruta al .jks (relativa a la raiz del proyecto LIVI).

storeFile=livi-release.jks
storePassword=PON_TU_PASSWORD_DEL_KEYSTORE
keyAlias=livi
keyPassword=PON_TU_PASSWORD_DEL_ALIAS
